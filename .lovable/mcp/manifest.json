        "outputSchema": null
      },
      {
        "name": "list_memories",
        "title": "List memories",
        "description": "List the couple's memories (shared moments) most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
